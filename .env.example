# --- Generation -------------------------------------------------------------
# Generation keys are server-side only, never exposed to the browser. With NO
# key set, /api/generate falls back to a deterministic local composer so the
# brief → render loop still works offline.
#
# Option A — Anthropic first-party (claude-opus-4-8, adaptive thinking):
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option B — OpenRouter (any model behind the OpenAI-compatible API):
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6   # any OpenRouter slug
#
# When BOTH keys are set, Anthropic wins. Pin one explicitly with:
# GENERATION_PROVIDER=anthropic|openrouter

# --- Rendering --------------------------------------------------------------
# Where the browser loads the live Slidev sidecar from (npm run slidev).
NEXT_PUBLIC_SLIDEV_URL=http://localhost:3101

# Where the server writes the active deck's Markdown. Defaults to
# ./slidev/slides.md; the Docker stack points it at the shared volume.
# SLIDES_PATH=/data/slides.md

# --- Pod (optional, only needed to SAVE decks) ------------------------------
# Pod base URL. Defaults to the local CSS on port 3102.
NEXT_PUBLIC_POD_BASE_URL=http://localhost:3102/

# OIDC issuer. Defaults to POD_BASE_URL when unset (see src/lib/solid/session.ts).
# In production every sibling points at https://pods.mindpods.org/ for SSO.
# NEXT_PUBLIC_SOLID_ISSUER=http://localhost:3102/
