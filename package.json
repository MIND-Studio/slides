{
  "name": "slides",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3160",
    "gen:icons": "node scripts/gen-icons.mjs",
    "predev": "npm run build:widget",
    "build": "next build",
    "prebuild": "npm run build:widget",
    "build:widget": "vite build -c widget/vite.config.ts",
    "start": "next start -p 3160",
    "slidev": "slidev slidev/slides.md --port 3161",
    "slidev:export": "slidev export slidev/slides.md",
    "worker": "node worker/server.mjs",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:gallery": "tsx scripts/build-active.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "tsx scripts/smoke.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "@inrupt/solid-client": "^3.0.0",
    "@inrupt/solid-client-authn-browser": "^4.0.0",
    "@inrupt/solid-client-authn-node": "^3.1.0",
    "@mind-studio/core": "^0.7.0",
    "@mind-studio/ui": "^0.7.0",
    "lucide-react": "^0.460.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "vitest": "^4.1.9",
    "@slidev/cli": "^51.0.0",
    "@slidev/theme-default": "latest",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-vue": "^5.2.1",
    "playwright-chromium": "^1.60.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vue": "^3.5.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
